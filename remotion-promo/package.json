{
  "name": "pixel-mart-promo",
  "version": "1.0.0",
  "description": "Pixel-Mart Vendor Promotional Video — Remotion",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render MainComposition out/pixel-mart-promo.mp4 --codec=h264 --crf=18",
    "render:scene1": "remotion render Scene1Intro out/scene1.mp4",
    "render:scene2": "remotion render Scene2CreateStore out/scene2.mp4",
    "render:scene3": "remotion render Scene3AddProduct out/scene3.mp4",
    "render:scene4": "remotion render Scene4Order out/scene4.mp4",
    "render:scene5": "remotion render Scene5Delivery out/scene5.mp4",
    "render:scene6": "remotion render Scene6Dashboard out/scene6.mp4",
    "render:scene7": "remotion render Scene7Outro out/scene7.mp4",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/google-fonts": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  },
  "remotion": {
    "entryPoint": "./src/index.ts"
  }
}
